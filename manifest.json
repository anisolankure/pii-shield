{
  "manifest_version": 3,
  "name": "PII Shield — AI Privacy Guard",
  "version": "1.0.3",
  "description": "Detects and alerts you when personally identifiable information (PII) is entered into AI tools. Protects your privacy automatically.",
  "default_locale": "en",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "PII Shield"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://www.bing.com/chat*",
        "https://www.perplexity.ai/*",
        "https://huggingface.co/chat*",
        "https://grok.com/*",
        "https://x.com/i/grok*"
      ],
      "js": ["pii-engine.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "storage",
    "sidePanel",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://copilot.microsoft.com/*",
    "https://www.bing.com/*",
    "https://www.perplexity.ai/*",
    "https://huggingface.co/*",
    "https://grok.com/*",
    "https://x.com/*"
  ],

  "commands": {
    "toggle-side-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Toggle PII Shield side panel"
    }
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/*.png", "sidepanel.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
